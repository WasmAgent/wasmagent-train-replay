# wasmagent-train-replay — environment variable template
# Copy this file to .env and adjust values for your environment.
#
# Prometheus integration (optional — leave PROMETHEUS_QUERY_URL empty to
# disable anomaly-source polling).

# Base URL of the Prometheus server.
PROMETHEUS_QUERY_URL=http://localhost:9090

# Poll interval in seconds for anomaly-source queries.
PROMETHEUS_POLL_INTERVAL=30

# Per-request HTTP timeout in seconds.
PROMETHEUS_TIMEOUT=10

# Optional Bearer token for Prometheus authentication.
# PROMETHEUS_BEARER_TOKEN=
